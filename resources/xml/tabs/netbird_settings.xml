<brls:Box
    width="auto"
    height="auto">

    <brls:ScrollingFrame
        width="auto"
        height="auto"
        axis="column"
        alignItems="stretch"
        grow="1.0">
        
        <brls:Box
            width="10000"
            height="auto"
            axis="column"
            alignItems="stretch"
            paddingTop="@style/brls/tab_details/padding_top"
            paddingRight="@style/brls/tab_details/padding_right"
            paddingBottom="@style/brls/tab_details/padding_bottom"
            paddingLeft="@style/brls/tab_details/padding_left">
            
            <brls:Header title="NetBird VPN"/>
            
            <brls:BooleanCell
                id="netbird_toggle"
                title="Enable NetBird VPN"/>
                
            <brls:InputCell
                id="netbird_server"
                title="Server URL"
                placeholder="https://netbird.example.com:9443"
                hint="NetBird management server URL"/>
                
            <brls:InputCell
                id="netbird_key"
                title="Setup Key"
                placeholder=""
                hint="Your NetBird setup key"/>
                
            <brls:Label
                id="netbird_status"
                text="Disconnected"
                fontSize="18"/>
                
        </brls:Box>
    </brls:ScrollingFrame>
</brls:Box>
